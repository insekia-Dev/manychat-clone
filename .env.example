# ===== DATABASE =====
MONGODB_URI=mongodb://admin:password@localhost:27017/manychat_clone?authSource=admin
POSTGRES_URL=postgresql://user:password@localhost:5432/manychat_clone
REDIS_URL=redis://localhost:6379

# ===== JWT AUTHENTICATION =====
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRE=30d

# ===== WHATSAPP CONFIGURATION =====
WHATSAPP_SESSION_PATH=./sessions
WHATSAPP_BAILEYS_VERSION=latest
WHATSAPP_AUTO_RECONNECT=true
WHATSAPP_RECONNECT_DELAY=5000

# ===== OPENAI AI CONFIGURATION =====
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ===== PAYMENT GATEWAYS =====
# Fapshi
FAPSHI_API_KEY=your_fapshi_public_key
FAPSHI_API_SECRET=your_fapshi_secret_key
FAPSHI_WEBHOOK_SECRET=your_fapshi_webhook_secret

# Mesomb
MESOMB_API_KEY=your_mesomb_api_key
MESOMB_API_SECRET=your_mesomb_api_secret
MESOMB_WEBHOOK_SECRET=your_mesomb_webhook_secret

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=pk_test_your_flutterwave_public_key
FLUTTERWAVE_SECRET_KEY=sk_test_your_flutterwave_secret_key
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_secret

# Swychr Connect
SWYCHR_API_KEY=your_swychr_api_key
SWYCHR_API_SECRET=your_swychr_api_secret
SWYCHR_WEBHOOK_SECRET=your_swychr_webhook_secret

# ===== WEBHOOK CONFIGURATION =====
WEBHOOK_URL=http://localhost:5000/api/webhooks
WEBHOOK_TIMEOUT=30000
WEBHOOK_RETRY_ATTEMPTS=3

# ===== SERVER CONFIGURATION =====
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000/api
SOCKET_URL=http://localhost:5000

# ===== EMAIL CONFIGURATION =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@manychat-clone.com
SMTP_FROM_NAME=ManyChat Clone

# ===== LOGGING =====
LOG_LEVEL=debug
LOG_FORMAT=json

# ===== FILE UPLOAD =====
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx
UPLOAD_PATH=./uploads

# ===== SECURITY =====
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=10

# ===== ADMIN SETTINGS =====
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_in_production

# ===== FEATURE FLAGS =====
ENABLE_AI_REPLIES=true
ENABLE_KNOWLEDGE_BASE=true
ENABLE_WEBHOOKS=true
ENABLE_TEAM_MANAGEMENT=true